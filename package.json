{
  "name": "sab-conversion-kit",
  "version": "1.0.0",
  "description": "SAB Conversion Kit adalah starter kit berbasis Tailwind CSS untuk membangun landing page dan komponen konversi tinggi (high-converting UI).",
  "main": "index.js",
  "scripts": {
    "dev": "tailwindcss -i ./assets/css/main.css -o ./assets/css/output.css --watch",
    "build": "tailwindcss -i ./assets/css/main.css -o ./assets/css/output.css --minify",
    "dev:service": "tailwindcss -i ./assets/css/main-service.css -o ./assets/css/output-service.css --watch",
    "build:service": "tailwindcss -i ./assets/css/main-service.css -o ./assets/css/output-service.css --minify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdulchalik/sab-conversion-kit.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/abdulchalik/sab-conversion-kit/issues"
  },
  "homepage": "https://github.com/abdulchalik/sab-conversion-kit#readme",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.14"
  }
}
